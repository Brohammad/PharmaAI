# PharmaIQ Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Gemini API ─────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here

# Primary model: fast agents (SENTINEL, PULSE, AEGIS, MERIDIAN)
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Validation model: CRITIQUE + COMPLIANCE agents
GEMINI_MODEL_VALIDATION=gemini-3.1-flash-lite-preview

# Synthesis model: NEXUS (decision) + CHRONICLE (report) — use full Pro
GEMINI_MODEL_SYNTHESIS=gemini-3.1-pro-preview

GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=8192

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Options: development | staging | production

# ── MCP Server URLs ────────────────────────────────────────────────────────────
# All MCP servers default to localhost for local development.
# In production, replace with actual service URLs.
COLD_CHAIN_MCP_URL=http://localhost:8010
ERP_MCP_URL=http://localhost:8011
HRMS_MCP_URL=http://localhost:8012
DISTRIBUTOR_MCP_URL=http://localhost:8013
EXTERNAL_INTEL_MCP_URL=http://localhost:8014
REGULATORY_KB_MCP_URL=http://localhost:8015
COMMUNICATION_MCP_URL=http://localhost:8016

# ── Authority Matrix Thresholds ────────────────────────────────────────────────
# Orders above auto_order_max_multiplier × standard qty require HUMAN_INFORMED
AUTO_ORDER_MAX_MULTIPLIER=2.5
# Orders above human_informed_order_max_multiplier × standard qty require HUMAN_REQUIRED
HUMAN_INFORMED_ORDER_MAX_MULTIPLIER=3.0
# Any single action > this value (in Lakh INR) triggers HUMAN_REQUIRED
HIGH_COST_ACTION_THRESHOLD_LAKH=2.0

# ── Cold Chain Thresholds ─────────────────────────────────────────────────────
COLD_CHAIN_NORMAL_MAX_TEMP=8.0
COLD_CHAIN_NORMAL_MIN_TEMP=2.0
COLD_CHAIN_SEVERE_TEMP=15.0
COLD_CHAIN_FREEZE_TEMP=0.0

# ── KPI Targets ───────────────────────────────────────────────────────────────
# Cold chain compliance target (fraction, not percentage)
COLD_CHAIN_COMPLIANCE_TARGET=0.998
# Expiry write-off rate target (fraction)
EXPIRY_WRITEOFF_TARGET=0.008
# Stockout rate target (fraction)
STOCKOUT_RATE_TARGET=0.002
# Schedule H compliance target (fraction)
SCHEDULE_H_COMPLIANCE_TARGET=1.0

# ── Scheduled Cycle Hours (IST = UTC+5:30) ────────────────────────────────────
MORNING_FORECAST_HOUR=5
MIDDAY_REFORECAST_HOUR=13
EXPIRY_REVIEW_HOUR=22
WEEKLY_BRIEF_HOUR=7
# Note: COMPLIANCE_SWEEP runs every 2 hours (no single hour configured)

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
AUDIT_LOG_PATH=./logs/audit.jsonl

# ── Authentication / JWT ────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string-before-deploying
JWT_EXPIRE_MINUTES=480
